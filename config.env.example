# ─────────────────────────────────────────────────────────────────────────────
# config.env.example — Project configuration template
#
# One-time local setup:
#   1. cp config.env.example config.env
#   2. Fill in the values below
#   3. python scripts/configure.py
#
# config.env is gitignored — never commit it.
# This file (config.env.example) IS in git as a template.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS ───────────────────────────────────────────────────────────────────────
# 12-digit AWS account ID
# Find it: aws sts get-caller-identity --query Account --output text
AWS_ACCOUNT_ID=431451850426

# AWS region where the cluster lives
AWS_REGION=us-west-1

# ── Domain ────────────────────────────────────────────────────────────────────
# Your registered domain.  The app will live at:
#   https://bookstore.<DOMAIN>
#   https://api.bookstore.<DOMAIN>
DOMAIN=maheshdev.xyz

# ── GitHub ────────────────────────────────────────────────────────────────────
# GitHub repo in  owner/repo  format.
# Used in the OIDC IAM role trust policy and in argocd/application.yaml.
GITHUB_REPO=adarsh0331/aws_three_tier_code.git
